  command = C:\WINDOWS\system32\cmd.exe /C "$PRE_LINK && E:\msys2\ucrt64\bin\cmake.exe -E rm -f $TARGET_FILE && E:\msys2\ucrt64\bin\ar.exe qc $TARGET_FILE $LINK_FLAGS $in && E:\msys2\ucrt64\bin\ranlib.exe $TARGET_FILE && $POST_BUILD"
