#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = E:\msys2\ucrt64\bin\cmake.exe --regenerate-during-build -SE:\TOYC -BE:\TOYC\artifacts\independent_audit\build_cpp
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = E:\msys2\ucrt64\bin\ninja.exe $FILE_ARG -t clean $TARGETS
