int a00 = 1;
int a01 = 2;
int a10 = 3;
int a11 = 4;
int b00 = 5;
int b01 = 6;
int b10 = 7;
int b11 = 8;

int main() {
    int i = 0;
    int s = 0;
    while (i < 1800000) {
        int c00 = (a00 * b00 + a01 * b10) % 251;
        int c01 = (a00 * b01 + a01 * b11) % 251;
        int c10 = (a10 * b00 + a11 * b10) % 251;
        int c11 = (a10 * b01 + a11 * b11) % 251;
        s = (s + c00 + c01 + c10 + c11) % 256;
        a00 = (a00 + 1) % 251;
        a01 = (a01 + 2) % 251;
        a10 = (a10 + 3) % 251;
        a11 = (a11 + 4) % 251;
        i = i + 1;
    }
    return s;
}
