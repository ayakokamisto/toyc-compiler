int main() {
    int i = 0;
    int s = 0;
    while (i < 4200000) {
        int a = i % 997;
        int b = (i + 17) % 991;
        int x1 = a * b + a - b;
        int x2 = a * b + a - b;
        int x3 = a * b + a - b;
        int x4 = a * b + a - b;
        s = (s + x1 + x2 - x3 + x4) % 256;
        i = i + 1;
    }
    return s;
}
