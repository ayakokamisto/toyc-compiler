int main() {
    int i = 0;
    int s = 0;
    while (i < 3500000) {
        int a = i % 97;
        int b = a * 31 + 7;
        int c = b * b - a * 13 + 99;
        int d = c * 5 + b * 3 - a;
        if (0) {
            s = s + d;
        }
        if (i % 11 == 0) {
            s = (s + a) % 256;
        } else {
            s = (s + 3) % 256;
        }
        i = i + 1;
    }
    return s;
}
