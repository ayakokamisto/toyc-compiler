int main() {
    int i = 0;
    int j = 0;
    int sum = 0;
    while (i < 4) {
        i = i + 1;
        if (i == 2) {
            continue;
        }
        j = 0;
        while (j < 5) {
            j = j + 1;
            if (j == 4) {
                break;
            }
            sum = sum + i * j;
        }
    }
    return sum;
}
